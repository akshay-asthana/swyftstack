# swyftstack-userapp — public marketing + customer-facing site.
#
# This file documents the environment variables the userapp reads. Only
# DATABASE_URL is strictly required; everything else has a sensible default
# (see swyftstack-shared/src/env.ts). On Vercel, set these via the Project
# Settings -> Environment Variables UI (do NOT commit a real .env).

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Control-plane Postgres (the same DB the platform/admin app uses). The
# userapp reads from it for the dynamic sitemap and the /api/db-browse route.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/swyftstack_control?sslmode=require"

# Optional but recommended on Supabase / connection-pooled hosts. Used by
# Prisma for migrations / direct connections; leave blank if you only have
# one URL.
DIRECT_URL=""

# ---------------------------------------------------------------------------
# Userapp-specific
# ---------------------------------------------------------------------------

# When set to "true" (or 1 / yes / on) every "Sign in" / "Sign up" CTA on the
# public site becomes "Request early access" pointing at
# /request-early-access. Use this for the pre-launch waitlist phase.
WAITLIST_MODE="false"

# Canonical site URL used in <link rel="canonical">, JSON-LD, and the
# sitemap. No trailing slash. Falls back to https://swyftstack.com if unset.
NEXT_PUBLIC_MARKETING_URL="https://swyftstack.com"

# ---------------------------------------------------------------------------
# Shared secrets (read via swyftstack-shared/src/env.ts)
# ---------------------------------------------------------------------------
# These are validated by the shared env schema when any code path imports
# from swyftstack-shared. The userapp itself does not actively use them at
# runtime today, but the schema will accept the defaults. Set them in
# production so the platform + userapp stay in lockstep on the same
# control-plane DB.

SECRET_ENCRYPTION_KEY=""
AUTH_SECRET=""
INTERNAL_API_TOKEN=""

# Platform / userapp base URLs. The userapp uses USERAPP_BASE_URL for
# absolute links in transactional emails it triggers from API routes.
PLATFORM_BASE_URL="https://admin.swyftstack.com"
USERAPP_BASE_URL="https://swyftstack.com"

# Email provider (optional — leave blank to log messages to stdout).
EMAIL_FROM="Swyftstack <no-reply@swyftstack.com>"
EMAIL_WEBHOOK_URL=""
ZEPTOMAIL_API_URL=""
ZEPTOMAIL_API_KEY=""
ZEPTOMAIL_FROM_EMAIL=""
ZEPTOMAIL_FROM_NAME="Swyftstack"

# Runtime
NODE_ENV="production"
LOG_LEVEL="info"
