# Control-plane database only. Customer Postgres clusters, object storage,
# backup targets and worker tuning are NOT configured here — they live in the
# control DB and are managed from the admin dashboard (Infrastructure page).
DATABASE_URL="postgresql://quickdock:quickdock@localhost:5432/quickdock_control"

# Required encryption/auth secrets
SECRET_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"
AUTH_SECRET="REPLACE_WITH_RANDOM_STRING"
INTERNAL_API_TOKEN="REPLACE_WITH_RANDOM_STRING"

# Bootstrap admin
PLATFORM_ADMIN_EMAIL="admin@quickdock.local"
PLATFORM_ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# URLs
PLATFORM_BASE_URL="http://localhost:3000"
USERAPP_BASE_URL="http://localhost:3001"

# Optional customer Google OAuth. The callback may stay on the platform app.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# Runtime
NODE_ENV="development"
LOG_LEVEL="debug"

# Optional dev-only local paths (used to seed the local_dev providers)
DEV_LOCAL_STORAGE_ROOT="./storage-local"
DEV_LOCAL_BACKUP_ROOT="./backups-local"

# Optional fallback worker defaults only (DB worker_configs override these)
DEFAULT_WORKER_POLL_INTERVAL_MS="2000"
DEFAULT_WORKER_CONCURRENCY="2"
DEFAULT_WORKER_LOCK_TIMEOUT_MS="300000"
