{
  "name": "swyftstack",
  "private": true,
  "version": "0.1.0",
  "description": "Swyftstack — Infra Control Plane: admin-first orchestration platform for a small PaaS/DBaaS.",
  "workspaces": [
    "swyftstack-shared",
    "swyftstack-platform",
    "swyftstack-workers",
    "swyftstack-userapp"
  ],
  "scripts": {
    "postinstall": "npm -w swyftstack-shared run prisma:generate",
    "db:generate": "npm -w swyftstack-shared run prisma:generate",
    "db:migrate": "npm -w swyftstack-shared run prisma:migrate",
    "db:push": "npm -w swyftstack-shared run prisma:push",
    "db:repair": "npm -w swyftstack-shared run db:repair",
    "db:seed": "npm -w swyftstack-shared run seed",
    "docker:up": "docker compose up -d postgres",
    "docker:down": "docker compose down",
    "dev:platform": "npm -w swyftstack-platform run dev",
    "dev:userapp": "npm -w swyftstack-userapp run dev",
    "dev:workers": "npm -w swyftstack-workers run dev",
    "dev:admin": "npm -w swyftstack-platform run dev",
    "dev:user": "npm -w swyftstack-userapp run dev",
    "dev:worker": "npm -w swyftstack-workers run dev",
    "build:shared": "npm -w swyftstack-shared run build",
    "build:platform": "npm -w swyftstack-platform run build",
    "build:userapp": "npm -w swyftstack-userapp run build",
    "build:workers": "npm -w swyftstack-workers run build",
    "build": "npm run build:shared && npm run build:platform && npm run build:userapp && npm run build:workers",
    "start:platform": "npm -w swyftstack-platform run start",
    "start:userapp": "npm -w swyftstack-userapp run start",
    "start:workers": "npm -w swyftstack-workers run start",
    "lint:platform": "npm -w swyftstack-platform run lint",
    "lint:userapp": "npm -w swyftstack-userapp run lint",
    "lint": "npm run lint:platform && npm run lint:userapp",
    "typecheck:shared": "npm -w swyftstack-shared run typecheck",
    "typecheck:platform": "npm -w swyftstack-platform run typecheck",
    "typecheck:userapp": "npm -w swyftstack-userapp run typecheck",
    "typecheck:workers": "npm -w swyftstack-workers run typecheck",
    "typecheck": "npm run typecheck:shared && npm run typecheck:platform && npm run typecheck:userapp && npm run typecheck:workers",
    "test": "npm -w swyftstack-shared run test"
  },
  "engines": {
    "node": ">=20"
  }
}
