{
  "name": "swyftstack-shared",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db.ts",
    "./jobs": "./src/jobs/index.ts",
    "./services": "./src/services/index.ts"
  },
  "scripts": {
    "prisma:generate": "node scripts/prisma-root-env.mjs generate",
    "prisma:migrate": "node scripts/prisma-root-env.mjs migrate dev",
    "prisma:push": "node scripts/prisma-root-env.mjs db push",
    "db:repair": "node scripts/apply-safe-migrations.mjs",
    "seed": "tsx src/seed.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
